syntax = "v1"

type (
    UserRequest {
        Id int64 `json:"id"`
    }

    UserResponse {
        Id   int64  `json:"id"`
        Name string `json:"name"`
        Age  int    `json:"age"`
    }
)

service gateway {
    @handler getUserHandler
    post /api/user/getUser (UserRequest) returns (UserResponse)
}